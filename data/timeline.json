[
  {
    "chapter": 1,
    "time_tag": "午后",
    "event": "叶尘在天桥摆摊算命，捡到一枚古铜钱，突然能看见周围人的气数。他救下被追杀的苏婉清，两人重逢。铜钱引起墨渊注意，暗中观察。",
    "characters": [
      "叶尘",
      "苏婉清",
      "墨渊"
    ],
    "location": "天桥",
    "importance": 3
  },
  {
    "chapter": 2,
    "time_tag": "次日",
    "event": "叶尘用铜钱帮人算命，屡试不爽，但发现每次使用后身体虚弱。赵无极派人来抢铜钱，叶尘与苏婉清逃往城外。",
    "characters": [
      "叶尘",
      "苏婉清",
      "赵无极"
    ],
    "location": "天桥、京城街道",
    "importance": 3
  },
  {
    "chapter": 3,
    "time_tag": "三日后",
    "event": "叶尘与苏婉清逃至青云山，遇到青玄子。青玄子认出铜钱，收叶尘为徒，开始传授气运之术。苏婉清在山上练剑。",
    "characters": [
      "叶尘",
      "苏婉清",
      "青玄子"
    ],
    "location": "青云山",
    "importance": 3
  },
  {
    "chapter": 4,
    "time_tag": "半月后",
    "event": "墨渊追至青云山，与叶尘交手。叶尘初学气运术，不敌。青玄子出面调解，揭露墨渊是自己师侄。墨渊透露铜钱共有九枚。",
    "characters": [
      "叶尘",
      "墨渊",
      "青玄子"
    ],
    "location": "青云山山脚",
    "importance": 3
  },
  {
    "chapter": 5,
    "time_tag": "一个月后",
    "event": "叶尘与苏婉清前往苏家旧址，发现地下密室，内有苏家祖传的铜钱线索和一本古籍。赵无极派人埋伏，叶尘用望气术脱险。",
    "characters": [
      "叶尘",
      "苏婉清",
      "赵无极手下"
    ],
    "location": "苏家旧址",
    "importance": 3
  },
  {
    "chapter": 6,
    "time_tag": "两个月后",
    "event": "叶尘根据地图前往西域荒漠，寻找气运宗门遗址。墨渊暗中跟随，两人在荒漠中遭遇沙暴和邪教教徒，被迫联手。",
    "characters": [
      "叶尘",
      "墨渊",
      "邪教教徒"
    ],
    "location": "西域荒漠",
    "importance": 3
  },
  {
    "chapter": 7,
    "time_tag": "进入荒漠后第五天",
    "event": "叶尘与墨渊找到气运宗门遗址，进入地下密室。密室中机关重重，两人合力破解，发现千年布局的真相：上古强者欲毁灭世界。",
    "characters": [
      "叶尘",
      "墨渊"
    ],
    "location": "地下密室",
    "importance": 3
  },
  {
    "chapter": 8,
    "time_tag": "当日深夜",
    "event": "邪教教主出现，夺走密室中的三枚铜钱，并重伤墨渊。叶尘拼死抵抗，青玄子赶到救援，三人逃出密室。赵无极在京城发动政变。",
    "characters": [
      "叶尘",
      "墨渊",
      "青玄子",
      "邪教教主"
    ],
    "location": "地下密室、西域荒漠",
    "importance": 3
  },
  {
    "chapter": 9,
    "time_tag": "三日后",
    "event": "叶尘等人赶回京城，阻止赵无极和邪教教主的计划。青玄子牺牲自己封印教主部分力量，叶尘与墨渊联手击败赵无极。苏婉清觉醒气运感应，助战。",
    "characters": [
      "叶尘",
      "苏婉清",
      "墨渊",
      "青玄子",
      "赵无极",
      "邪教教主"
    ],
    "location": "京城皇宫",
    "importance": 3
  },
  {
    "chapter": 10,
    "time_tag": "一个月后",
    "event": "叶尘用转命术将铜钱之力封印于青云山，与苏婉清归隐。墨渊伤愈后离去。叶尘感知到气运之线仍在流转，暗示未来还有波澜。",
    "characters": [
      "叶尘",
      "苏婉清",
      "墨渊"
    ],
    "location": "青云山",
    "importance": 3
  },
