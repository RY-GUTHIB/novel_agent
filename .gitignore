# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
dist/
build/
*.egg

# ChromaDB vector store (large binary)
data/vector_db/
projects/*/data/vector_db/

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db
desktop.ini

# Env / secrets
.env
.env.local

# Main entry point (contains API keys, keep local only)
main.py

# Output (generated chapters, can be regenerated)
projects/*/output/

# Runtime state (program-generated, not source)
.current_project

# Project runtime data (generated by program, not source code)
projects/*/data/
data/

# Logs
*.log
